];

function clusterGeometry(geometry: { top: number; left?: number; right?: number; width: number; height: number }) {
  return {
    top: (geometry.top / fieldHeight) * 100,
    left: geometry.left == null ? undefined : (geometry.left / fieldWidth) * 100,
    right: geometry.right == null ? undefined : (geometry.right / fieldWidth) * 100,
    width: (geometry.width / fieldWidth) * 100,
    height: (geometry.height / fieldHeight) * 100
  };
}

function labelGeometry(geometry: { top: number; left: number }, clusterWidth: number, clusterHeight: number) {
  return {
    top: (geometry.top / clusterHeight) * 100,
    left: (geometry.left / clusterWidth) * 100
  };
}

function tagGeometry(
  tag: Omit<AttentionTagConfig, "geometry">,
  geometry: { top: number; left: number; width: number; height: number },
  clusterWidth: number,
  clusterHeight: number
): AttentionTagConfig {
  return {
    ...tag,
    geometry: {
      top: (geometry.top / clusterHeight) * 100,
      left: (geometry.left / clusterWidth) * 100,
      width: (geometry.width / clusterWidth) * 100,
      height: (geometry.height / clusterHeight) * 100
    }
  };
}
